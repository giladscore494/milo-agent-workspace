{
  "apiVersion": "serving.knative.dev/v1",
  "kind": "Service",
  "metadata": {
    "name": "milo-api",
    "namespace": "123456789012",
    "labels": {
      "cloud.googleapis.com/location": "us-central1"
    },
    "annotations": {
      "run.googleapis.com/ingress": "all"
    }
  },
  "spec": {
    "template": {
      "metadata": {
        "name": "milo-api-rel-0123456789ab",
        "annotations": {
          "run.googleapis.com/execution-environment": "gen2"
        }
      },
      "spec": {
        "containerConcurrency": 80,
        "timeoutSeconds": 300,
        "serviceAccountName": "milo-api-sa@milo-prod.iam.gserviceaccount.com",
        "containers": [
          {
            "image": "us-central1-docker.pkg.dev/milo-prod/milo/milo-api:0123456789abcdef0123456789abcdef01234567",
            "ports": [
              {
                "name": "http1",
                "containerPort": 8080
              }
            ],
            "env": [
              {
                "name": "ENVIRONMENT",
                "value": "production"
              },
              {
                "name": "JOB_LAUNCHER",
                "value": "disabled"
              }
            ]
          }
        ]
      }
    },
    "traffic": [
      {
        "percent": 100,
        "latestRevision": true
      }
    ]
  },
  "status": {
    "latestReadyRevisionName": "milo-api-rel-0123456789ab",
    "url": "https://milo-api-abcdefghij-uc.a.run.app"
  }
}
